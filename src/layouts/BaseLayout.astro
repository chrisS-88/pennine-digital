---
import Footer from "../components/Footer.astro";
import Nav from "../components/Nav.astro";
import "../styles/global.css";

const { title } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Lora:wght@400;700&family=Poppins:wght@400;500;600&display=swap" rel="stylesheet" />

    <title>{title}</title>
    <meta name="description" content="Modern, fast and reliable websites for small businesses across Bradford and West Yorkshire." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://penninedigital.co.uk/" />
    <meta property="og:title" content="Pennine Digital — Clean, Reliable Websites for West Yorkshire" />
    <meta property="og:description" content="Modern, fast and reliable websites for small businesses across Bradford and West Yorkshire." />
    <meta property="og:image" content="https://penninedigital.co.uk/og_image.jpg" />
  </head>
  <body class="text-dark font-sans">
    <Nav />
    <slot />
    <Footer />
  </body>
</html>
