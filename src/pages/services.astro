---
import ServiceCard from "../components/ServiceCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/Button.astro";

const serviceCards = [
  {
    title: "Web Design",
    description:
      "Clean layouts that feel welcoming and easy to navigate. I focus on clarity, accessibility, and a visual style that reflects your business without feeling cluttered or over‑designed.",
    listHeader: "Includes",
    list: ["Page layouts", "Colour and typography", "Mobile‑first design", "Brand consistency"],
  },
  {
    title: "Website Development",
    description:
      "Fast, reliable websites built on a lightweight, hand‑coded foundation. Everything is structured to load quickly, work smoothly across devices, and stay easy to update as your business grows.",
    listHeader: "Includes",
    list: ["Responsive builds", "Clean, maintainable code", "Performance optimisation", "SEO‑friendly structure"],
  },
  {
    title: "Website Care & Maintenance",
    description:
      "Reliable help with the small technical jobs that keep your website running smoothly. From updates and fixes to content changes and general housekeeping, I look after the details so you don’t have to.",
    listHeader: "Includes",
    list: ["Minor fixes", "Small updates", "Content changes", "General maintenance"],
  },
  {
    title: "Website Audit",
    description:
      "A practical review of your existing website to understand what’s working, what isn’t, and where improvements can be made. Clear, honest feedback with simple steps you can act on.",
    listHeader: "Includes",
    list: ["Performance review", "Design and usability feedback", "Mobile experience check", "Practical improvement suggestions"],
  },
];

const faqs = [
  {
    question: "How long does a website take to build?",
    answer: "Most one‑page sites take around 1–2 weeks, and full websites take 3–5 weeks depending on content and feedback.",
  },
  {
    question: "Do I need to provide the text and photos?",
    answer:
      "Yes — you know your business best. I’ll guide you on what to write and how much you need, and I can tidy up wording if needed.",
  },
  {
    question: "Can I update the website myself?",
    answer:
      "Most small businesses don’t need a CMS, so I handle updates for you. If you’re on the Monthly Care Plan, you get up to two small content updates each month — perfect for keeping things fresh.",
  },
  {
    question: "What’s included in the Monthly Care Plan?",
    answer:
      "Hosting, security updates, backups, uptime monitoring and up to two small content updates per month. It keeps your site running smoothly without you needing to worry about anything technical.",
  },
  {
    question: "What counts as a small content update?",
    answer:
      "Small updates include things like swapping photos, updating text, adding a testimonial or changing opening hours. Larger changes — such as new pages, redesigns or new features — are quoted separately.",
  },
  {
    question: "How does payment work?",
    answer: "A 50% deposit secures your project, and the remaining 50% is due when the site goes live.",
  },
  {
    question: "What’s the process?",
    answer: [
      "Quick chat about your business",
      "You send over content (text + photos)",
      "I design and build your website",
      "You review and request tweaks",
      "We launch the site",
      "Optional care plan begins",
    ],
    isList: true,
  },
  {
    question: "Do you work with businesses outside Yorkshire?",
    answer: "Yes — but I specialise in helping local, independent businesses across West Yorkshire.",
  },
];
---

<BaseLayout title="Pennine Digital - Services">
  <section class="bg-primary pt-44 pb-24">
    <div class="px-6 max-w-lg mx-auto">
      <p class="text-sm uppercase tracking-wide text-highlight mb-2">What I Do</p>
      <h1 class="text-4xl md:text-5xl font-heading font-semibold text-brand-200 max-w-sm">
        Simple, modern websites shaped <span class="italic">around your business.</span>
      </h1>

      <p class="mt-10 text-brand-200/80 text-xl font-thin leading-relaxed max-w-sm">
        I design and build websites that are clear to use, quick to load, and shaped around how your business actually works. Each one is
        built by hand, keeping things lightweight, intentional, and free from the noise of templates or unnecessary extras.
      </p>
    </div>
  </section>

  <section class="bg-brand-50 py-24">
    <div class="px-6 max-w-3xl mx-auto text-center">
      <h2 class="text-center font-heading text-3xl mb-10 text-brand-900">Services</h2>

      <p class="leading-relaxed">
        Running a small business is demanding enough — your website shouldn’t make things harder. I build sites that feel clear, intuitive,
        and genuinely useful, whether you’re starting fresh or improving what you already have.
      </p>
    </div>

    <div class="px-6 py-24 max-w-lg mx-auto grid gap-10 grid-cols-1 md:grid-cols-2">
      {serviceCards.map((item) => <ServiceCard {...item} />)}
    </div>

    <div class="max-w-lg mx-auto mt-16 py-12 text-center">
      <p class="text-xl font-semibold">Not sure what you need?</p>
      <p class="max-w-sm mx-auto leading-relaxed">
        If you're unsure which direction to take, we can look at your website together and figure out the best approach for your business.
      </p>
      <a href="/contact"><p class="mt-4 text-lg underline hover:text-accent transition-all duration-200">Start a Conversation</p></a>
    </div>
  </section>

  <section class="bg-brand-100 py-24">
    <div class="max-w-md mx-auto">
      <h2 class="text-center font-heading text-3xl mb-10 text-brand-900">Frequently Asked Questions</h2>

      <div class="space-y-8">
        {
          faqs.map((faq) => (
            <div class=" p-6 border-b border-brand-300">
              <h3 class="font-semibold text-lg mb-2">{faq.question}</h3>

              {faq.isList ? (
                <ul class="text-sm space-y-2 mt-2">
                  {faq.answer.map((step) => (
                    <li class="flex items-center gap-2">
                      <span class="text-accent font-bold leading-6">•</span>
                      <span>{step}</span>
                    </li>
                  ))}
                </ul>
              ) : (
                <p class="leading-relaxed">{faq.answer}</p>
              )}
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="bg-primary text-brand-200 text-center">
    <div class="max-w-md mx-auto px-6 py-28">
      <h2 class="font-heading text-4xl mb-6">Ready to start your project?</h2>

      <p class="leading-relaxed text-brand-200/80 max-w-xl mx-auto">
        Whether you have a clear plan or just an idea, I’d love to hear what you’re working on. No pressure — just a friendly chat about
        what you need.
      </p>

      <div class="mt-10 flex flex-col items-center gap-2">
        <Button href="/contact" title="Start Your Project" variant="ghost" />
        <p class="text-sm mt-4 text-brand-200/70">No obligation — just a quick conversation.</p>
      </div>
    </div>
  </section>
</BaseLayout>
