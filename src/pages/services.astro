---
import ServiceCard from "../components/ServiceCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/Button.astro";
import SeperationSvg from "../components/icons/SeperationSvg.astro";

const serviceCards = [
  {
    title: "Web Design",
    description:
      "Thoughtful layouts that feel welcoming and easy to navigate. I focus on clarity, accessibility, and a visual style that reflects your business without feeling corporate or over-designed.",
    listHeader: "Includes",
    list: ["Page layouts", "Colour and typography", "Mobile-first design", "Brand consistency"],
  },
  {
    title: "Website Development",
    description:
      "Fast, reliable websites built with modern technology. Everything is structured to load quickly, work smoothly across devices, and remain easy to update over time.",
    listHeader: "Includes",
    list: ["Responsive builds", "Clean, maintainable code", "Performance optimisation", "SEO-friendly structure"],
  },
  {
    title: "Website Care & Maintenance",
    description:
      "Quiet, reliable help with the small technical jobs that keep your website running smoothly — updates, fixes, and general housekeeping.",
    listHeader: "Includes",
    list: ["Minor fixes", "Small updates", "General maintenance", "Technical support"],
  },
  {
    title: "Content & Updates",
    description:
      "Support with keeping your website fresh as your business evolves — whether that’s new photos, updated services, or small changes to existing pages.",
    listHeader: "Includes",
    list: ["Content updates", "Photo and gallery changes", "Service or menu updates", "New sections or pages"],
  },
  {
    title: "Website Audit",
    description: "A practical review of your existing website to identify what’s working, what isn’t, and where improvements can be made.",
    listHeader: "Includes",
    list: ["Performance review", "Design and usability feedback", "Mobile experience check", "Practical improvement suggestions"],
  },
  {
    variant: "cta",
    title: "Not sure what you need?",
    description:
      "If you're unsure which service fits your business, we can talk through your website and figure out the best approach together.",
  },
];

const faqs = [
  {
    question: "How long does a project take?",
    answer: "Most small websites take 2–4 weeks depending on size and content. I’ll always give you a clear timeline before we begin.",
  },
  {
    question: "Do you work with existing websites?",
    answer: "Yes — I can improve, rebuild, or modernise what you already have. Whether it needs a refresh or a full overhaul, I can help.",
  },
  {
    question: "Do you offer ongoing support?",
    answer:
      "Absolutely. I offer simple monthly plans with no long contracts. You can hand over updates, fixes, and improvements whenever you need them.",
  },
  {
    question: "What do you need from me to get started?",
    answer:
      "Usually just a short chat, any existing content you want to use, and an idea of what you’re aiming for. I guide you through the rest.",
  },
];
---

<BaseLayout title="Pennine Digital - Services">
  <section class="bg-background pt-44 pb-12">
    <div class="px-6 max-w-2xl text-center mx-auto">
      <h1 class="text-4xl md:text-5xl font-heading font-semibold leading-tight">Websites that help your business run smoother</h1>

      <p class="mt-5 text-dark/75 text-lg leading-relaxed max-w-xl mx-auto">
        I design and build modern, thoughtful websites that are easy to use, simple to update, and shaped around how your business actually
        works.
      </p>
    </div>

    <div class="flex justify-center items-center mt-10 text-secondary/70">
      <SeperationSvg />
    </div>
  </section>

  <section class="bg-background pb-24">
    <div class="px-6 max-w-3xl mx-auto text-center">
      <p class="text-2xl font-medium text-secondary/80 font-heading uppercase tracking-wider mb-6">Services</p>
      <p class="text-lg text-dark/75 leading-relaxed">
        Running a small business is demanding enough. Your website shouldn’t add to the stress. I create sites that feel calm, intuitive,
        and genuinely useful — whether you’re starting fresh or improving what you already have.
      </p>
    </div>

    <div class="px-6 py-24 max-w-6xl mx-auto grid gap-10 grid-cols-1 md:grid-cols-2 lg:grid-cols-3">
      {serviceCards.map((item) => <ServiceCard {...item} />)}
    </div>
  </section>

  <section class="bg-background pb-28">
    <div class="px-6 text-center max-w-3xl mx-auto">
      <h2 class="font-heading text-3xl md:text-4xl">How the process works</h2>

      <p class="mt-4 text-dark/70 text-lg leading-relaxed">
        A simple, straightforward approach that keeps everything clear from the start.
      </p>
    </div>

    <div class="mt-20 px-6 max-w-5xl mx-auto flex flex-col gap-16 lg:flex-row">
      <!-- Step -->
      <div class="group flex-1 text-center lg:text-left">
        <div class="text-5xl inline-block font-heading text-primary/40 group-hover:text-primaryHover/50 transition-colors">01</div>

        <h3 class="font-semibold text-xl text-dark mt-2">Chat</h3>

        <p class="text-dark/70 leading-relaxed mt-4">
          We begin with a quick conversation about what you need, what’s working, and what isn’t. No pressure, no technical talk — just a
          chance to understand your goals.
        </p>
      </div>

      <!-- Step -->
      <div class="group flex-1 text-center lg:text-left">
        <div class="text-5xl inline-block font-heading text-primary/40 group-hover:text-primaryHover/50 transition-colors">02</div>

        <h3 class="font-semibold text-xl text-dark mt-2">Design</h3>

        <p class="text-dark/70 leading-relaxed mt-4">
          I shape the structure, layout, and visual direction so everything feels clear and natural. You’ll see how the site will work
          before anything is built.
        </p>
      </div>

      <!-- Step -->
      <div class="group flex-1 text-center lg:text-left">
        <div class="text-5xl inline-block font-heading text-primary/40 group-hover:text-primaryHover/50 transition-colors">03</div>

        <h3 class="font-semibold text-xl text-dark mt-2">Build</h3>

        <p class="text-dark/70 leading-relaxed mt-4">
          Your website is built using modern, reliable tools with performance and long-term maintainability in mind.
        </p>
      </div>
    </div>
  </section>

  <section class="bg-gradient-soft">
    <div class="py-28 max-w-3xl mx-auto px-6">
      <h2 class="text-3xl md:text-4xl font-heading mb-16 text-center">Frequently asked questions</h2>

      <div class="space-y-10">
        {
          faqs.map((faq) => (
            <div class="pb-8 border-b border-dark/10 last:border-none">
              <h3 class="text-lg md:text-xl font-semibold text-dark">{faq.question}</h3>

              <p class="mt-4 text-dark/75 leading-relaxed">{faq.answer}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="bg-gradient-cta text-background text-center">
    <div class="max-w-3xl mx-auto px-6 py-28">
      <h2 class="font-heading text-3xl md:text-4xl mb-6">Ready to start your project?</h2>

      <p class="leading-relaxed text-light/70 max-w-xl mx-auto">
        Whether you have a clear plan or just an idea, I’d love to hear what you’re working on. No pressure — just a friendly chat about
        what you need.
      </p>

      <div class="mt-10 flex flex-col items-center gap-2">
        <Button href="/contact" title="Start Your Project" variant="main" />
        <p class="text-sm mt-4 text-light/50">No obligation — just a quick conversation.</p>
      </div>
    </div>
  </section>
</BaseLayout>
