---
import Button from "../components/Button.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import loftMockup from "../assets/projects/loft_mockup.webp";
---

<BaseLayout title="Pennine Digital - Work">
  <div class="bg-gradient-soft">
    <section class="pt-44 pb-24">
      <div class="px-6 max-w-2xl text-center mx-auto">
        <h1 class="text-4xl md:text-5xl font-heading font-semibold">My Work</h1>

        <p class="mt-4 text-dark/75 text-lg">
          A selection of real and concept websites that showcase my approach to clean design, clarity, and helping small businesses guide
          customers to the next step.
        </p>
      </div>
    </section>

    <section class="pb-24">
      <div class="max-w-6xl mx-auto px-6 grid gap-8">
        <ProjectCard
          title="The Loft Café — Concept Website"
          description="A self‑initiated concept project exploring a clean, welcoming website for a modern local café. Not commissioned or affiliated with The Loft Café."
          image={loftMockup}
          link="https://loftcafe.netlify.app/"
          list={["Mobile-first layout", "Clear navigation", "Fast loading performance"]}
          tech={["Astro", "Tailwind", "Responsive Design", "Netlify"]}
        />
      </div>
    </section>
  </div>

  <section class="bg-gradient-cta text-center text-background">
    <div class="max-w-3xl mx-auto px-6 py-28">
      <h2 class="font-heading text-3xl md:text-4xl mb-6">Have a project in mind?</h2>

      <p class="text-light/70 max-w-xl mx-auto">
        If you'd like something similar for your business, I'd love to hear about what you're working on.
      </p>

      <div class="mt-10 flex justify-center">
        <Button href="/contact" title="Start Your Project" variant="main" />
      </div>
    </div>
  </section>
</BaseLayout>
