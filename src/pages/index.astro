---
import Hero from "../components/Hero.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/Button.astro";
import FeatureCard from "../components/FeatureCard.astro";
import DesignSvg from "../components/icons/DesignSvg.astro";
import AutomationSvg from "../components/icons/AutomationSvg.astro";
import SupportSvg from "../components/icons/SupportSvg.astro";
import AboutSvg from "../components/icons/AboutSvg.astro";

const serviceCardDetails = [
  {
    title: "Web Design & Branding",
    description: "Clean, modern websites that reflect your business and feel easy to use.",
    icon: DesignSvg,
  },
  {
    title: "Practical Features",
    description: "Simple, helpful tools like contact forms, menus, galleries, and booking links.",
    icon: AutomationSvg,
  },
  {
    title: "Support & Care",
    description: "Friendly ongoing help, updates, and guidance as your website grows.",
    icon: SupportSvg,
  },
];

const projectsCardDetails = [
  {
    title: "Coming Soon",
    description: "I’m putting together a small set of examples to show the kind of thoughtful, easy‑to‑use websites I build.",
  },
];
---

<BaseLayout title="Pennine Digital">
  <section>
    <Hero />
  </section>

  <section class="bg-gradient-soft w-full">
    <div class="max-w-6xl text-center px-6 py-28 mx-auto">
      <h2 class="font-heading text-3xl mb-3">Websites built around how you work</h2>
      <p class="text-lg">
        Supporting Bradford and West Yorkshire businesses with clean, modern design and simple features that help you run things smoothly.
      </p>

      <div class="mt-12 mb-16 md:flex gap-6">
        {
          serviceCardDetails.map((item) => (
            <div class="flex-1 mx-auto mb-6">
              <FeatureCard key={item.title} {...item} variant="services" />
            </div>
          ))
        }
      </div>
      <Button href="/services" title="View Services" variant="light" />
    </div>
  </section>

  <section class="bg-gradient-dark text-center">
    <div class="max-w-6xl text-center px-6 py-28 mx-auto h-full">
      <h2 class="font-heading text-3xl mb-6 text-light">Recent Work</h2>
      <p class="max-w-3xl mx-auto text-lg text-light">
        I’m putting together a small set of projects to show how I approach web design and development, with more examples on the way.
      </p>

      <div class="mt-12 mb-16 md:grid grid-cols-1 gap-6 items-stretch">
        {
          projectsCardDetails.map((item) => (
            <div class="mx-auto mb-6">
              <FeatureCard key={item.title} {...item} variant="projects" />
            </div>
          ))
        }
      </div>
      <Button href="/" title="View Projects" variant="dark" />
    </div>
  </section>

  <section class="bg-gradient-soft/60">
    <div
      class="max-w-6xl px-6 pt-24 pb-20 flex flex-col items-center justify-evenly gap-12 lg:flex-row text-center lg:text-left text-balance">
      <div class="max-w-lg lg:max-w-lg">
        <h2 class="font-heading text-3xl mb-6">A friendly, local partner for your website</h2>
        <p class="mb-6">
          I’m Chris — a front‑end developer from West Yorkshire who likes building websites that feel honest, approachable, and genuinely
          helpful. I work with small businesses who want something simple, clear, and trustworthy, without the jargon.
        </p>
        <p>
          I focus on clean design, small thoughtful touches, and practical features that make day‑to‑day tasks easier. After years of
          building maintainable front‑end systems, I’m now bringing that experience into my freelance work.
        </p>
      </div>
      <AboutSvg />
    </div>
    <div class="flex justify-center pb-28">
      <Button href="/about" title="More About Me" variant="light" />
    </div>
  </section>

  <section class="bg-gradient-dark text-center text-light">
    <div class="max-w-4xl mx-auto px-6 pt-28 pb-20">
      <h2 class="font-heading text-3xl mb-6">Ready to build a website that feels right for your business</h2>
      <p class="leading-relaxed text-light/70">
        Whether you’re starting fresh or improving what you already have, I’d love to help you create something clean, modern, and genuinely
        useful for your customers.
      </p>
    </div>

    <div class="flex justify-center pb-28">
      <Button href="/contact" title="Start Your Project" variant="main" />
    </div>
  </section>
</BaseLayout>
