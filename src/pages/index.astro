---
import Hero from "../components/Hero.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/Button.astro";
import FeatureCard from "../components/FeatureCard.astro";
import DesignSvg from "../components/icons/DesignSvg.astro";
import FeaturesSvg from "../components/icons/FeaturesSvg.astro";
import SupportSvg from "../components/icons/SupportSvg.astro";
import AboutSvg from "../components/icons/AboutSvg.astro";
import UserSvg from "../components/icons/UserSvg.astro";
import LightningSvg from "../components/icons/LightningSvg.astro";
import ShieldSvg from "../components/icons/ShieldSvg.astro";

const serviceCardDetails = [
  {
    title: "Web Design & Branding",
    description: "A clean, modern website designed to reflect your business and create a strong first impression.",
    icon: DesignSvg,
  },
  {
    title: "Practical Features",
    description: "Clear pages, contact forms, and simple ways for customers to get in touch — all set up properly.",
    icon: FeaturesSvg,
  },
  {
    title: "Personal Service",
    description: "Direct support from start to finish. I’m here for updates, changes, and honest advice whenever you need it.",
    icon: SupportSvg,
  },
];

const projectsCardDetails = [
  {
    title: "Projects Coming Soon",
    description: "I'm currently working with a few local businesses and will be sharing some recent website projects here soon.",
  },
];

const pricingPlans = [
  {
    title: "One-Page Website",
    price: "From £450",
    description:
      "A simple, professional website that puts your business online quickly. Perfect for cafés, trades and small businesses that need a clear place for customers to learn about you and get in touch.",
  },
  {
    title: "Full Website",
    price: "From £950",
    description:
      "A fully tailored multi-page website designed around your business. Clear navigation, strong design, and structured pages that help customers understand what you offer and trust your brand.",
  },
  {
    title: "Monthly Care Plan",
    price: "From £40/month",
    description:
      "Ongoing hosting, updates, backups and small content changes so your website stays secure, up to date, and running smoothly without you needing to worry about the technical side.",
  },
];

const trustPoints = [
  {
    title: "Personal Service",
    description:
      "From first chat to launch and beyond, I’m here to answer questions, make updates, and give honest advice whenever you need it.",
    icon: UserSvg,
  },
  {
    title: "Easy to Use",
    description: "Websites that are simple for your customers to use, with updates and changes handled quickly whenever you need them.",
    icon: LightningSvg,
  },
  {
    title: "Built to Last",
    description: "Thoughtful design and practical features ensure your website continues to work well as your business grows.",
    icon: ShieldSvg,
  },
];
---

<BaseLayout title="Pennine Digital">
  <section>
    <Hero />
  </section>

  <section class="bg-gradient-soft w-full">
    <div class="max-w-6xl text-center px-6 py-28 mx-auto">
      <h2 class="font-heading text-3xl mb-3">Simple, well-built websites for local businesses</h2>

      <p class="text-lg max-w-2xl mx-auto text-dark/80">
        Helping small businesses and creatives across Bradford and West Yorkshire with clean, modern websites that are simple to use and
        built to last.
      </p>

      <div class="mt-12 mb-16 md:flex gap-6">
        {
          serviceCardDetails.map((item) => (
            <div class="flex-1 mx-auto mb-6">
              <FeatureCard key={item.title} {...item} variant="services" />
            </div>
          ))
        }
      </div>

      <Button href="/services" title="View Services" variant="light" />
    </div>
  </section>

  <section class="bg-background">
    <div class="max-w-6xl mx-auto px-6 py-28 text-center">
      <h2 class="font-heading text-3xl mb-3">Simple, transparent pricing</h2>

      <p class="text-lg max-w-3xl mx-auto text-dark/80">
        Clear pricing with no surprises. I work with small businesses around Bradford and West Yorkshire to create reliable, modern websites
        with a straightforward process from first conversation to launch.
      </p>

      <div class="mt-12 mb-16 grid md:grid-cols-3 gap-6">
        {pricingPlans.map((plan) => <FeatureCard {...plan} variant="pricing" />)}
      </div>

      <div class="max-w-3xl mx-auto mb-12">
        <h4 class="font-heading text-lg mb-3">Optional extras</h4>

        <ul class="text-dark/80 leading-relaxed space-y-1">
          <li>Branding and logo design</li>
          <li>Simple business photography</li>
          <li>Online booking integration</li>
          <li>Digital menus</li>
          <li>Google Business Profile setup</li>
        </ul>
      </div>

      <Button href="/contact" title="Start Your Project" variant="light" />
    </div>
  </section>

  <section class="bg-gradient-dark text-center">
    <div class="max-w-6xl text-center px-6 py-28 mx-auto h-full">
      <h2 class="font-heading text-3xl mb-6 text-background">Recent Work</h2>

      <p class="max-w-3xl mx-auto text-lg text-background/80">
        A look at some of the websites I’ve been working on for small businesses. Each project focuses on clean design, clear content, and
        making it easy for customers to get in touch.
      </p>

      <div class="mt-12 mb-16 flex justify-center">
        {
          projectsCardDetails.map((item) => (
            <div class="max-w-md">
              <FeatureCard {...item} variant="projects" />
            </div>
          ))
        }
      </div>

      <Button href="/projects" title="View Projects" variant="dark" />
    </div>
  </section>

  <section class="bg-gradient-soft">
    <div
      class="max-w-6xl px-6 pt-24 pb-20 flex flex-col items-center justify-evenly gap-12 lg:flex-row text-center lg:text-left text-balance">
      <div class="max-w-lg lg:max-w-lg">
        <h2 class="font-heading text-3xl mb-6">A friendly, local partner for your website</h2>

        <p class="mb-6">
          I’m Chris — a web developer based in Riddlesden, West Yorkshire. I build clean, reliable websites for small businesses that want
          something simple, clear, and easy for customers to use.
        </p>

        <p>
          My focus is on thoughtful design and practical features that make day-to-day things easier — whether that’s helping customers get
          in touch, find your services, or book with you online. I keep things straightforward, explain everything clearly, and aim to be
          someone you can rely on as your website grows.
        </p>
      </div>

      <AboutSvg />
    </div>

    <div class="flex justify-center pb-28">
      <Button href="/about" title="More About Me" variant="light" />
    </div>
  </section>

  <section class="bg-background py-28 text-center">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="font-heading text-3xl mb-6">Why work with me?</h2>

      <p class="max-w-3xl mx-auto text-dark/80 mb-12 text-lg">
        I help small businesses across Bradford and West Yorkshire get online with websites that are clear, practical, and easy for your
        customers to use. Here’s what you can expect when we work together:
      </p>

      <div class="grid md:grid-cols-3 gap-8 mb-12">
        {trustPoints.map((point) => <FeatureCard {...point} variant="trust" iconPosition="top" />)}
      </div>
    </div>
  </section>

  <section class="bg-gradient-cta text-center text-background pb-28">
    <div class="max-w-4xl mx-auto px-6 pt-28 pb-20">
      <h2 class="font-heading text-3xl mb-6">Thinking about a new website?</h2>

      <p class="leading-relaxed text-background/80 text-lg">
        If you’re a small business in Bradford or West Yorkshire looking for a clean, reliable website, I’d be happy to chat about what you
        need. No pressure — just a friendly conversation to see if it’s the right fit.
      </p>
    </div>

    <Button href="/contact" title="Start Your Project" variant="main" />

    <p class="text-background/80 text-sm mt-4">Or email me directly at hello@yourdomain.co.uk</p>
  </section>
</BaseLayout>
