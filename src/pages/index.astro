---
import Hero from "../components/Hero.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/Button.astro";
import FeatureCard from "../components/FeatureCard.astro";
import { Image } from "astro:assets";
import ProjectCard from "../components/ProjectCard.astro";
import formFirstScreenshot from "../assets/projects/form-first/screenshot.webp";
import loftCafeScreenshot from "../assets/projects/loft-cafe/screenshot.webp";
import macbook from "../assets/images/macbook.webp";
import Shopfront from "../components/icons/Shopfront.astro";
import Tools from "../components/icons/Tools.astro";
import Cutlery from "../components/icons/Cutlery.astro";
import Creative from "../components/icons/Creative.astro";

const serviceCardDetails = [
  {
    title: "Local Shops",
    description: "Modern storefronts for independent boutiques and retail.",
    icon: Shopfront,
  },
  {
    title: "Skilled Trades",
    description: "Clear, professional sites for builders, plumbers, and craftspeople.",
    icon: Tools,
  },
  {
    title: "Cafés & Dining",
    description: "Digital menus and simple booking for local food spots.",
    icon: Cutlery,
  },
  {
    title: "Creatives",
    description: "Portfolio sites that let your work take center stage.",
    icon: Creative,
  },
];

const pricingPlans = [
  {
    title: "Presence",
    price: 550,
    description: "A simple, confident website to get you online",
    includes: ["Single‑page design", "Mobile‑friendly layout", "Clear, simple messaging", "Basic SEO setup", "Contact form"],
  },
  {
    title: "Identity",
    price: 900,
    description: "A more complete website with room to grow",
    includes: ["Multi‑page website", "Human, easy‑to‑read copy", "Improved contact form", "Stronger site structure", "Better user journey"],
  },
  {
    title: "Experience",
    price: 1400,
    description: "A crafted website with tools that support your workflow",
    includes: ["Up to 5 pages", "Third‑party integrations", "Enhanced SEO foundations", "Performance tuning", "Launch support"],
  },
];
---

<BaseLayout title="Pennine Digital">
  <section>
    <Hero />
  </section>

  <section class="bg-brand-100 pt-28 pb-24">
    <div class="max-w-lg px-6 mx-auto gap-16 grid md:grid-cols-2 items-center">
      <div class="max-w-xs">
        <p class="text-sm uppercase tracking-wide text-accent">Expertise</p>

        <h2 class="font-heading text-brand-900 text-4xl mb-10">
          Fast, reliable, and <span class="block italic">built with intention.</span>
        </h2>

        <p class="mb-6">
          Your website should feel effortless — quick to load, simple to use, and clear in its purpose. I focus on speed, clarity, and
          reliability so your customers get the best experience every time they visit.
        </p>

        <ul class="space-y-4">
          <li class="flex items-start gap-4">
            <span class="block w-4 h-[2px] bg-accent mt-3"></span>
            <span>Blazing‑fast load times that keep visitors engaged</span>
          </li>
          <li class="flex items-start gap-4">
            <span class="block w-4 h-[2px] pt-[2px] bg-accent mt-3"></span>
            <span>Mobile‑first layouts that feel natural on every device</span>
          </li>
          <li class="flex items-start gap-4">
            <span class="block w-4 h-[2px] pt-[2px] bg-accent mt-3"></span>
            <span>A stable, lightweight build that stays fast over time</span>
          </li>
        </ul>
      </div>
      <div class="relative inline-block mx-12 md:m-0">
        <Image src={macbook} alt="MacBook mockup" class="w-full saturate-0 relative z-10" />

        <div class="absolute inset-0 border border-accent translate-x-3 translate-y-3 z-0"></div>
      </div>
    </div>
  </section>

  <section class="py-24 bg-primary text-brand-200">
    <div class="lg:max-w-lg mx-auto px-6 lg:px-0 space-y-20">
      <div>
        <h2 class="font-heading leading-tight text-4xl md:max-w-sm">
          Supporting small businesses with <span class="italic text-highlight">clarity and craft.</span>
        </h2>

        <p class="text-xl font-thin mt-6 text-brand-200/80">
          I build fast, simple websites that help small businesses show up online with confidence.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {serviceCardDetails.map((s) => <FeatureCard {...s} variant="services" iconPosition="top-left" />)}
      </div>
    </div>
  </section>

  <section class="py-24 bg-brand-200/60">
    <div class="lg:max-w-lg mx-auto px-6 md:flex md:justify-between">
      <div>
        <p class="text-sm uppercase tracking-wide text-accent">What I bring</p>
        <h2 class="font-heading text-brand-900 leading-tight text-4xl md:max-w-sm">
          Why work <span class="italic">with me?</span>
        </h2>
      </div>

      <div class="space-y-8 md:max-w-xs pl-4 md:pl-0 mt-16">
        <div>
          <h4 class="text-2xl italic font-heading text-brand-900">Direct Communication</h4>
          <p>You work directly with the person building your site. It keeps the process simple and the decisions clear.</p>
        </div>

        <div>
          <h4 class="text-2xl italic font-heading text-brand-900">Technical Expertise</h4>
          <p>
            I build everything myself, without templates or page builders. It means your site is lightweight, fast, and put together with
            care rather than assembled from parts.
          </p>
        </div>

        <div>
          <h4 class="text-2xl italic font-heading text-brand-900">Clarity First</h4>
          <p>A focus on simple structures and thoughtful design, so the site feels clean and easy to use.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-brand-100 py-24">
    <div class="px-6 text-center">
      <p class="text-sm uppercase tracking-wide text-accent">How I Work</p>

      <h2 class="font-heading text-brand-900 text-4xl">
        A simple, <span class="italic">three step journey.</span>
      </h2>
    </div>

    <div class="mt-20 px-6 max-w-lg mx-auto grid md:grid-cols-3 gap-20 text-brand-900">
      <!-- Step -->
      <div class="relative flex-1 text-center">
        <div class="absolute inline-block -top-8 md:-top-16 text-8xl md:text-9xl font-heading text-primary/5">01</div>

        <h3 class="font-semibold text-xl mt-2">The Chat</h3>

        <p class="text-brand-900/70 leading-relaxed mt-4">
          We begin with a quick conversation to understand your business goals and your customers' needs.
        </p>
      </div>

      <!-- Step -->
      <div class="relative flex-1 text-center">
        <div class="absolute inline-block -top-8 md:-top-16 text-8xl md:text-9xl font-heading text-primary/5">02</div>

        <h3 class="font-semibold text-xl mt-2">The Build</h3>

        <p class="text-brand-900/70 leading-relaxed mt-4">
          Your website is built using modern, reliable tools with performance and long-term maintainability in mind.
        </p>
      </div>

      <!-- Step -->
      <div class="relative flex-1 text-center">
        <div class="absolute inline-block -top-8 md:-top-16 text-8xl md:text-9xl font-heading text-primary/5">03</div>

        <h3 class="font-semibold text-xl mt-2">The Launch</h3>

        <p class="text-brand-900/70 leading-relaxed mt-4">
          We go live. I handle the hosting and tech, so you can get back to running your business.
        </p>
      </div>
    </div>
  </section>

  <section class="bg-primary py-24">
    <div class="lg:max-w-lg mx-auto px-6">
      <div>
        <p class="text-sm uppercase tracking-wide text-highlight">Selected Projects</p>

        <div class="flex justify-between items-end">
          <h2 class="font-heading text-brand-200 leading-tight text-4xl md:max-w-sm">
            Recent <span class="italic">builds.</span>
          </h2>
          <a href="/projects" class="font-thin text-sm text-brand-200/80 hover:text-brand-200 transition-all duration-300 uppercase"
            >View All Projects</a
          >
        </div>
      </div>
    </div>

    <div class="grid md:grid-cols-2 gap-12 max-w-lg mx-auto mt-24 px-6">
      <div class="md:-translate-y-6">
        <ProjectCard
          title="Form First"
          subtitle="Design & Booking Flow"
          description="A simple demo showing a clear booking flow with lookup and a small admin view."
          image={formFirstScreenshot}
          href="/projects/form-first"
        />
      </div>

      <div class="md:translate-y-6">
        <ProjectCard
          title="Loft Café - Mockup"
          subtitle="Design, digital menu & gallery"
          description="A light, modern website mockup exploring how a small independent café could present itself online."
          note="This is a concept piece and isn’t affiliated with The Loft Café."
          image={loftCafeScreenshot}
          href="/projects/loft-cafe"
        />
      </div>
    </div>
  </section>

  <section class="bg-brand-50 py-24">
    <div class="max-w-xl mx-auto px-6 md:px-16 text-center">
      <h2 class="font-heading text-brand-900 leading-tight text-4xl">
        Clear, honest <span class="italic">pricing.</span>
      </h2>

      <p class="mx-auto mt-6 font-thin text-xl max-w-sm">
        No hidden fees or complex contracts. Just high-quality web development tailored to your business.
      </p>

      <div class="mt-16 mb-16 grid md:grid-cols-3 gap-16">
        {pricingPlans.map((plan, i) => <FeatureCard index={i} {...plan} variant="pricing" button="helo" />)}
      </div>

      <div class="bg-brand-100 border border-brand-900/10 p-8 flex justify-between">
        <div class="text-left">
          <h3 class="text-xl font-heading">Monthly Care Plan</h3>
          <p class="text-brand-900/70 font-thin italic">Peace of mind with ongoing updates, security and hosting</p>

          <ul class="mt-4 text-brand-900/70 text-sm space-y-2">
            <li class="flex gap-2">
              <span class="text-accent font-bold">✓</span>
              <span>Ongoing updates and maintenance</span>
            </li>
            <li class="flex gap-2">
              <span class="text-accent font-bold">✓</span>
              <span>Security monitoring and backups</span>
            </li>
            <li class="flex gap-2">
              <span class="text-accent font-bold">✓</span>
              <span>Small content tweaks each month</span>
            </li>
            <li class="flex gap-2">
              <span class="text-accent font-bold">✓</span>
              <span>Fast, reliable hosting</span>
            </li>
          </ul>
        </div>

        <div>
          <p class="font-heading text-4xl">£35<span class="text-base text-brand-900/60">/mo</span></p>
        </div>
      </div>

      <div class="max-w-lg mx-auto mt-20">
        <h4 class="font-heading text-2xl text-brand-900 italic mb-16">Optional extras to support your business</h4>

        <div class="grid md:grid-cols-3 gap-10">
          <div class="border border-brand-900/10 p-4 text-center">
            <span class="text-accent block mb-1">£200</span>
            <h4 class="text-lg font-thin text-brand-900">Starter Brand Pack</h4>
          </div>

          <div class="border border-brand-900/10 p-4 text-center">
            <span class="text-accent block mb-1">£95</span>
            <h4 class="text-lg font-thin text-brand-900">Local SEO Boost</h4>
          </div>

          <div class="border border-brand-900/10 p-4 text-center">
            <span class="text-accent block mb-1">From £150</span>
            <h4 class="text-lg font-thin text-brand-900">Digital Menus</h4>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-brand-100 text-center pb-28">
    <div class="max-w-4xl mx-auto px-6 pt-28 pb-20">
      <h2 class="font-heading text-4xl mb-6">Thinking about a new website?</h2>

      <p class="leading-relaxed">
        If you’re looking for a simple, fast, and dependable website, I’d be happy to talk things through. No pressure — just a
        straightforward chat to see if it’s the right fit.
      </p>
    </div>

    <Button href="/contact" title="Start a conversation" variant="main" />

    <p class="text-brand-900/80 text-sm mt-4">
      Or email me directly at
      <a href="mailto:hello@penninedigital.co.uk" class="text-brand-900/60 hover:text-accent transition"> hello@penninedigital.co.uk </a>
    </p>
  </section>
</BaseLayout>
