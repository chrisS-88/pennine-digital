---
import Layout from "../layouts/BaseLayout.astro";
---

<Layout title="Pennine Digital - Message sent">
  <section class="pt-48 pb-24 bg-background">
    <div class="max-w-2xl mx-auto text-center px-6">
      <h1 class="text-4xl font-heading font-semibold">Thanks for your message</h1>

      <p class="text-brand-900/70 mt-4 leading-relaxed">
        I really appreciate you getting in touch. I’ll read your message and get back to you as soon as I can — usually within one working
        day.
      </p>

      <a href="/" class="inline-block mt-10 px-4 py-2 text-brand-100 bg-primary/80 hover:bg-primary transition"> Back to Home </a>
    </div>
  </section>
</Layout>
