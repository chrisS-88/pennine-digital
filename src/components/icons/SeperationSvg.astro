---
const { size = 26 } = Astro.props;
---

<div class="flex items-center justify-center w-full my-12 text-accent/50">
  <span class="h-px w-20 bg-accent/50"></span>

  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" aria-hidden="true" class="stroke-current mx-4">
    <path
      d="M12 3.5V7.5M12 16.5V20.5M4 12H8M16 12H20
        M6.2 6.2L8.7 8.7M15.3 15.3L17.8 17.8
        M6.2 17.8L8.7 15.3M15.3 8.7L17.8 6.2"
      stroke-width="1"
      stroke-linecap="round"
      stroke-linejoin="round"></path>
  </svg>

  <span class="h-px w-20 bg-accent/50"></span>
</div>
