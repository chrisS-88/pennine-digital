---
import { navLinks } from "../data/navLinks";
import MailSvg from "./icons/MailSvg.astro";
import logo from "../assets/logos/logo.png";
import { Image } from "astro:assets";
---

<footer class="bg-[#061217] border-t border-white/5 text-background font-heading pt-20 pb-10">
  <div class="max-w-5xl mx-auto px-6">
    <div class="text-center mb-12">
      <Image src={logo} alt="Pennine Digital Logo" class="w-16 mx-auto mb-3" />

      <p class="text-xl font-semibold tracking-wide">Pennine Digital</p>

      <p class="text-background/70 mt-2 max-w-md mx-auto text-sm leading-relaxed">
        Clean, reliable websites for small businesses across Bradford and West Yorkshire.
      </p>

      <p class="text-background/70 text-sm mt-2">Based in Riddlesden, West Yorkshire</p>
    </div>

    <div class="h-px bg-accent/20 mb-10"></div>

    <ul class="flex justify-center gap-6 mb-10 text-background/70 text-sm">
      {
        navLinks.map((link) => (
          <li>
            <a href={link.href} class="hover:text-accent transition-colors duration-200">
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="flex justify-center gap-6 mb-10">
      <a href="mailto:hello@penninedigital.co.uk" class="flex items-center gap-2 text-background/70 hover:text-accent transition">
        <MailSvg class="w-5 h-5" />
        <span class="text-sm">hello@penninedigital.co.uk</span>
      </a>
    </div>

    <div class="text-center mt-6 space-y-1">
      <p class="text-sm text-background/60">
        © {new Date().getFullYear()} Pennine Digital · All rights reserved
      </p>

      <p class="text-xs text-background/40 tracking-wide">Built with Astro</p>
    </div>
  </div>
</footer>
