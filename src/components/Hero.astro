---
import hero from "/public/hero_1.jpg";
import Button from "./Button.astro";
---

<section class="relative mt-20 h-[90vh]">
  <img src={hero.src} alt="hero image" class="w-full h-full object-cover absolute" />
  <div class="absolute inset-0 bg-dark/70"></div>

  <div class="h-full flex flex-col justify-center gap-12 px-6 md:px-12">
    <div class="relative z-10 max-w-2xl mr-auto text-background">
      <p class="text-sm uppercase tracking-wide text-background/80">Web design for small businesses across West Yorkshire</p>

      <h1 class="mt-4 text-4xl md:text-6xl font-semibold tracking-tight">Websites that feel right for your business</h1>

      <p class="mt-8 text-lg max-w-lg text-background/80">
        I build clean, modern websites for small businesses and creatives — easy to use, built properly, and supported with personal service
        from start to finish.
      </p>
    </div>

    <div class="relative z-10 flex flex-col md:flex-row gap-4">
      <Button href="/contact" title="Let’s Have a Chat" variant="main" />
      <Button href="/projects" title="Take a Look at My Work" variant="dark" />
    </div>
  </div>
</section>
