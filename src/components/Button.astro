---
const { title, href, variant } = Astro.props;

const variants = {
  main: "bg-accent text-primary border border-transparent hover:bg-accent/90 transition-colors duration-200",
  light: "text-accent border border-accent/60 hover:bg-accent/10 transition-colors duration-200",
  ghost: "text-brand-100 border border-accent/40 hover:border-accent hover:bg-brand-100/5 transition-colors duration-200",
};
---

<a
  href={href}
  class={`inline-block text-center w-60 uppercase px-4 py-2 transition-all duration-300 ${variants[variant as keyof typeof variants]}`}>
  {title}
</a>
