---
const { title, description, image, link, list = [], tech = [] } = Astro.props;
import { Image } from "astro:assets";
---

<div class="bg-white/40 border border-dark/10 rounded-lg overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-300">
  <div class="overflow-hidden rounded-t-lg">
    <Image src={image} alt={title} class="w-full object-cover rounded-t-lg" />
  </div>

  <div class="p-6 space-y-4">
    <h3 class="text-xl font-heading font-semibold text-dark">
      {title}
    </h3>

    <p class="text-dark/70 text-sm leading-relaxed">
      {description}
    </p>

    {
      list.length > 0 && (
        <ul class="space-y-1 text-sm text-dark/70 mt-2">
          {list.map((item) => (
            <li class="flex items-start gap-2">
              <span class="text-accent">•</span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      )
    }

    {
      tech.length > 0 && (
        <div class="flex flex-wrap gap-2 text-xs text-dark/60">
          {tech.map((item) => (
            <span class="bg-muted/10 px-2 py-1 rounded">{item}</span>
          ))}
        </div>
      )
    }

    {
      link && (
        <a href={link} class="inline-block text-accent text-sm font-medium hover:underline" target="_blank">
          View Website →
        </a>
      )
    }
  </div>
</div>
